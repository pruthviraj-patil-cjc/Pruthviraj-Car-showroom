    <section id="home" class="hero">
        <div class="hero-content">
            <h1 class="hero-title">Premium Cars in Hyderabad</h1>
            <p class="hero-subtitle">Experience luxury vehicles with 3D viewing and instant purchase options</p>
            <div class="hero-buttons">
                <a href="#showcase" class="cta-btn"><i class="fas fa-cube"></i> 3D Showcase</a>
                <a href="#buy" class="cta-btn"><i class="fas fa-shopping-cart"></i> Buy Now</a>
            </div>
        </div>
    </section>

    <!-- 3D Showcase -->
    <section id="showcase" class="showcase-section">
        <div class="container">
            <h2 class="section-title">Interactive 3D Viewer</h2>
            <div class="car-3d-container">
                <div class="car-3d-viewer" id="car3DViewer">
                    <div class="car-3d-model" id="car3DModel">
                        <div class="car-3d-side car-3d-front"></div>
                        <div class="car
